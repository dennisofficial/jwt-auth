{
  "name": "@workspace/auth",
  "version": "1.0.0",
  "description": "Package description",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./src/index.ts",
        "default": "./dist/index.js"
      }
    },
    "./server": {
      "import": {
        "types": "./src/server/index.ts",
        "default": "./dist/server/index.mjs"
      },
      "require": {
        "types": "./src/server/index.ts",
        "default": "./dist/server/index.js"
      }
    },
    "./dto": {
      "import": {
        "types": "./src/dto/index.ts",
        "default": "./dist/dto/index.mjs"
      },
      "require": {
        "types": "./src/dto/index.ts",
        "default": "./dist/dto/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm tsup && pnpm install --prefer-offline --ignore-scripts --frozen-lockfile",
    "dev": "nodemon",
    "prepare": "tsup"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@swc/core": "^1.15.32",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "class-validator": "^0.15.1",
    "jose": "^6.2.3",
    "jwt-decode": "^4.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19"
  }
}
